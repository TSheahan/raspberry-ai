#!/usr/bin/env bash
# pre-push hook — remind to deploy to Pi after push, or auto-deploy.
#
# Install (one-time, from repo root):
#   cp scripts/hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push        # needed on Linux/Mac; Git for Windows handles it
#
# Override Pi target if needed:
#   export PI_HOST=192.168.1.21         # default: morpheus
#   export PI_REPO=~/raspberry-ai       # default: ~/raspberry-ai

PI_HOST="${PI_HOST:-morpheus}"
PI_REPO="${PI_REPO:-~/raspberry-ai}"

# ---- Option A: reminder only (default) ----
echo "[pre-push] Push in progress. After it completes, deploy to Pi:"
echo "[pre-push]   bash scripts/deploy.sh"

# ---- Option B: auto-deploy in background ----
# Uncomment to automatically trigger a Pi pull ~8s after this hook fires.
# 8s gives enough time for a typical push to origin to complete over LAN.
# Check /tmp/pi-deploy.log if the Pi hasn't updated.
#
# nohup bash -c \
#   "sleep 8 && ssh ${PI_HOST} 'git -C ${PI_REPO} pull --ff-only'" \
#   > /tmp/pi-deploy.log 2>&1 &
# echo "[pre-push] Pi deploy queued (8s) — tail /tmp/pi-deploy.log to confirm"

exit 0
