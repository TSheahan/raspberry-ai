#!/usr/bin/env bash
# Supervising launcher for the Cursor CLI (agent user). Spec:
# mvp-modules/forked_assistant/spec/cursor_agent_wrapper_spec.md
set -uo pipefail

readonly LOG_FILE=/var/log/agent-wrapper.log
readonly DEFAULT_REAL=/home/agent/.local/bin/agent
REAL_BIN="${CURSOR_AGENT_REAL_BIN:-${AGENT_REAL_BIN:-$DEFAULT_REAL}}"

ts() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

log_line() {
  local line="$1"
  if echo "$line" >>"$LOG_FILE" 2>/dev/null; then
    return 0
  fi
  echo "$line" >&2
}

log_event() {
  local event="$1"
  shift
  log_line "$(ts) event=${event} $*"
}

# Argv is flags/paths only; transcript is on stdin (CursorAgentSession). Cap length for logs.
argv_summary() {
  local combined="" a
  for a in "$@"; do
    combined+="${combined:+ }${a}"
  done
  local max=900
  if ((${#combined} > max)); then
    printf '%s...(truncated %d chars)' "${combined:0:max}" "$((${#combined} - max))"
  else
    printf '%s' "$combined"
  fi
}

main() {
  local sum
  sum="$(argv_summary "$@")"
  sum="${sum//$'\n'/\\n}"
  log_event start "resolved_real=${REAL_BIN} argv_summary=${sum}"

  if [[ ! -x "$REAL_BIN" ]]; then
    log_event fatal "missing_or_not_executable path=${REAL_BIN}"
    exit 127
  fi

  # Give the real CLI its own process group (via setsid) so the wrapper
  # can kill -TERM the entire child tree on teardown.  Bash & redirects
  # the child's stdin to /dev/null, so we save stdin to fd 3 first and
  # re-attach it to the setsid child.
  exec 3<&0

  # No separate `command -v setsid` probe: Pi profile assumes util-linux;
  # absence surfaces as a shell start failure instead of log_event fatal.
  setsid -- "$REAL_BIN" "$@" <&3 &
  local child=$!
  exec 3<&-

  log_event spawn_real "child_pid=${child} real_bin=${REAL_BIN}"

  forward_signal() {
    local name="$1"
    log_event signal_forward "sig=${name} kill_target=-${child}"
    # INT and TERM both send TERM to the group so the CLI can exit cleanly
    # (same signal as a typical service stop).
    kill -TERM -- -"${child}" 2>/dev/null || true
  }

  # child is assigned before traps are installed; no empty-PGID forward in normal runs.
  trap 'forward_signal TERM' TERM
  trap 'forward_signal INT'  INT

  local wait_status=0
  wait "$child" || wait_status=$?

  trap - TERM INT
  log_event exit "child_exit=${wait_status}"
  exit "$wait_status"
}

main "$@"
