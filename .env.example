# .env.example — copy to .env and fill in real values
# .env is gitignored; never commit the real file.

# Deepgram — STT (streaming WebSocket) and TTS (Aura REST)
# Same key covers both; already in Pi venv (deepgram-sdk).
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs — TTS streaming (Phase 2a evaluation)
# Requires: pip install elevenlabs  (not yet in Pi venv as of 2026-04-05)
# Obtain at: elevenlabs.io — Profile → API Keys  (key starts with sk_...)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Cartesia — TTS WebSocket streaming (Phase 2b evaluation, optional)
# Requires: pip install cartesia  (not yet in Pi venv as of 2026-04-05)
# Obtain at: https://play.cartesia.ai
# CARTESIA_API_KEY=your_cartesia_api_key_here

# Cursor agent subprocess (EU-6 privilege separation)
# Set AGENT_USER to enable sudo -u agent execution; leave unset for dev runs.
# See mvp-modules/forked_assistant/AGENTS.md — "Agent Subprocess" section.
# AGENT_USER=agent
# AGENT_BIN=/home/agent/.local/bin/agent
# AGENT_WORKSPACE=/home/agent/workspace
